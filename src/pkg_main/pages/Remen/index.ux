<template>
  <div class="page">
    <list class="remen-list">
      <list-item type="header" class="header-section">
        <stack class="header-stack">
          <image class="top-bg" src="../../assets/img/hotceping-bg.png"></image>
          <div class="tabs-container">
            <block for="{{tabs}}">
              <div
                class="{{'tab-item ' + (activeSource === $item.key ? 'active' : '')}}"
                onclick="switchTab($item.key)"
              >
                <text
                  class="{{'tab-text ' + (activeSource === $item.key ? 'active-text' : '')}}"
                  >{{$item.title}}</text
                >
              </div>
            </block>
          </div>
        </stack>
      </list-item>

      <list-item type="list" class="list-section">
        <div class="list-container">
          <block for="{{testList}}">
            <div class="list-item" onclick="startTest($item.id, $item.title)">
              <stack class="img-wrapper">
                <image class="item-img" src="{{$item.image}}" style="background-color: #eeeeee;"></image>
                <div class="play-count-box">
                  <div class="play-count-inner">
                    <text class="play-count">{{$item.playCountStr}}人测试</text>
                  </div>
                </div>
              </stack>
              <text class="item-title">{{$item.title}}</text>
            </div>
          </block>
        </div>
        <text class="empty-tip" if="{{testList.length === 0}}">暂无测评数据</text>
      </list-item>

      <list-item type="spacer" class="bottom-spacer"></list-item>
    </list>
  </div>
</template>

<script>
import router from '@system.router'
import { getRemenTabs, getRemenListBySource } from '../../../helper/JS/remenDataAdapter'
import { personalityTest } from '../../../helper/JS/xingge'
import { careerTest } from '../../../helper/JS/shiye'
import { loveCoupleTest } from '../../../helper/JS/aiqing'
import { funTest } from '../../../helper/JS/quwei'

const LOCAL_SOURCE_CONFIG = {
  xingge: {
    tab: '性格',
    tag: '性格',
    imagePrefix: 'https://cdn.shijinzhuang.com/quick/fuycp/rmcp/xg/',
    data: personalityTest
  },
  shiye: {
    tab: '事业',
    tag: '事业',
    imagePrefix: 'https://cdn.shijinzhuang.com/quick/fuycp/rmcp/sy/',
    data: careerTest
  },
  aiqing: {
    tab: '爱情',
    tag: '爱情',
    imagePrefix: 'https://cdn.shijinzhuang.com/quick/fuycp/rmcp/aq/',
    data: loveCoupleTest
  },
  quwei: {
    tab: '趣味',
    tag: '趣味',
    imagePrefix: 'https://cdn.shijinzhuang.com/quick/fuycp/rmcp/qw/',
    data: funTest
  }
}

function getLocalTabs() {
  return Object.keys(LOCAL_SOURCE_CONFIG).map(function(key) {
    return {
      key: key,
      title: LOCAL_SOURCE_CONFIG[key].tab
    }
  })
}

function getLocalListBySource(source) {
  const cfg = LOCAL_SOURCE_CONFIG[source]
  if (!cfg || !cfg.data || !Array.isArray(cfg.data.testList)) {
    return []
  }

  return cfg.data.testList.map(function(item) {
    return {
      id: item.id,
      title: item.name,
      tag: cfg.tag,
      source: source,
      image: cfg.imagePrefix + String(item.id) + '.jpg'
    }
  })
}

export default {
  data() {
    return {
      activeSource: 'xingge',
      tabs: [],
      testList: []
    }
  },

  onInit() {
    const adapterTabs = getRemenTabs() || []
    this.tabs = adapterTabs.length > 0 ? adapterTabs : getLocalTabs()
    this.refreshList()
  },

  refreshList() {
    const adapterList = getRemenListBySource(this.activeSource) || []
    let list = adapterList.length > 0 ? adapterList : getLocalListBySource(this.activeSource)
    
    list = list.map(function(item) {
      if (item.playCountStr) return item
      var seed = String(item.id || item.title || '').split('').reduce(function(a, b) {
        return a + b.charCodeAt(0)
      }, 0)
      var count = (seed * 8761 + 30000) % 150000 + 40000
      var countStr = String(count).replace(/\B(?=(\d{3})+(?!\d))/g, ',')
      return Object.assign({}, item, { playCountStr: countStr })
    })

    this.testList = list
  },

  switchTab(source) {
    if (!source || source === this.activeSource) {
      return
    }
    this.activeSource = source
    this.refreshList()
  },

  startTest(testId, testName) {
    router.push({
      uri: '/pkg_main/pages/RemenDati',
      params: {
        catTitle: this.activeSource,
        testId: String(testId),
        testName: testName,
        testSource: this.activeSource
      }
    })
  }
}
</script>

