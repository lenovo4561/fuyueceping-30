.page {
  flex-direction: column;
  flex: 1;
  width: 100%;
  height: 100%;
  background-color: #f7f8f9;
}

.remen-list {
  flex: 1;
  width: 100%;
}

.header-section {
  width: 100%;
  height: 120px;
}

.header-stack {
  width: 100%;
  height: 120px;
}

.top-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tabs-container {
  flex-direction: row;
  justify-content: space-around;
  align-items: flex-end;
  width: 100%;
  height: 100%;
  padding-bottom: 0px;
}

.tab-item {
  width: 52px;
  height: 28px;
  border-radius: 14px;
  background-color: #ffffff;
  justify-content: center;
  align-items: center;
}

.active {
  background-color: #000000;
}

.tab-text {
  font-size: 11px;
  color: #333333;
}

.active-text {
  color: #ffffff;
}

.list-section {
  flex-direction: column;
  width: 100%;
}

.list-container {
  width: 100%;
  padding: 10px;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
}

.list-item {
  width: 110px;
  flex-direction: column;
  background-color: transparent;
  margin-bottom: 20px;
  align-items: flex-start;
}

.img-wrapper {
  width: 110px;
  height: 100px;
  border-radius: 8px;
}

.item-img {
  width: 110px;
  height: 100px;
  border-radius: 8px;
  object-fit: cover;
}

.play-count-box {
  width: 100%;
  height: 100%;
  flex-direction: column;
  justify-content: flex-end;
  align-items: flex-start;
  padding-bottom: 6px;
  padding-left: 6px;
}

.play-count-inner {
  background-color: rgba(0, 0, 0, 0.4);
  border-radius: 8px;
  padding: 2px 5px;
}

.play-count {
  font-size: 7px;
  color: #ffffff;
}

.item-title {
  font-size: 9px;
  color: #333333;
  lines: 1;
  text-overflow: ellipsis;
  margin-top: 8px;
  font-weight: bold;
}

.bottom-spacer {
  width: 100%;
  height: 70px;
}

.empty-tip {
  width: 100%;
  text-align: center;
  color: #999999;
  font-size: 10px;
  margin-top: 20px;
}
</style>

