  background-color: #EDEEF2;
  margin-top: 3px;
  margin-bottom: 9px;
}

.source-title {
  margin-bottom: 8px;
}

.source-grid {
  justify-content: space-between;
  flex-wrap: wrap;
}

.source-item {
  width: 23%;
  height: 24px;
  background-color: rgba(239, 241, 244, 0.8);
  border-radius: 12px;
  justify-content: center;
  align-items: center;
  margin-bottom: 5px;
}

.source-item-large {
  width: 48%;
}

.source-item-active {
  background-color: #CFEFFF;
}

.source-name {
  font-size: 11px;
  color: #747B84;
}

.source-name-active {
  color: #28AEEA;
}

.feeling-input {
  width: 100%;
  height: 96px;
  margin-top: 3px;
  font-size: 11px;
  color: #333333;
  padding: 8px 10px;
  border-radius: 8px;
  background-color: #FFFFFF;
  placeholder-color: #A7ADB5;
}

.submit-item {
  width: 100%;
  flex-direction: column;
  padding-left: 10px;
  padding-right: 10px;
  padding-top: 15px;
