  width: 100%;
  height: 140px;
  padding: 0;
}

.top-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.grid-section {
  flex-direction: column;
  align-items: stretch;
  width: 100%;
  padding: 0 10px;
  margin-top: -44px;
}

.grid-content {
  align-self: stretch;
  flex-direction: column;
  background-color: #ffffff;
  border-radius: 12px;
  padding: 10px 10px 0 10px;
}

.grid-item {
  width: 100%;
  flex-direction: column;
  margin-bottom: 12px;
  background-color: #f6f6f6;
  border-radius: 8px;
  overflow: hidden;
}

.item-img {
  width: 100%;
  height: 140px;
  object-fit: cover;
  background-color: #eeeeee;
  border-top-left-radius: 8px;
  border-top-right-radius: 8px;
}

.item-title-box {
  width: 100%;
  padding: 10px 8px;
  justify-content: flex-start;
  align-items: center;
}

.item-title {
  font-size: 12px;
  color: #333333;
  lines: 1;
  text-overflow: ellipsis;
}

.bottom-spacer {
  width: 100%;
  height: 72px;
}
</style>
