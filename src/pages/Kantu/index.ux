<template>
  <div class="page">
    <list class="kantu-list">
      <list-item type="header" class="kantu-header">
        <image class="top-bg" src="../../assets/img/kantuceping-bg1.png"></image>
      </list-item>

      <list-item type="content" class="grid-section">
        <div class="grid-content">
          <block for="{{kantuList}}">
            <div class="grid-item" onclick="goToTest($item.id)">
              <image class="item-img" src="{{$item.image}}"></image>
              <div class="item-title-box">
                <text class="item-title">{{$item.title}}</text>
              </div>
            </div>
          </block>
        </div>
      </list-item>

      <list-item type="spacer" class="bottom-spacer"></list-item>
    </list>
  </div>
</template>

<script>
import router from '@system.router'
import { imagePersonalityTest } from '../../helper/JS/tupianceshi'

export default {
  private: {
    kantuList: []
  },

  onInit() {
    const list = (imagePersonalityTest && imagePersonalityTest.testList) || []
    this.kantuList = list.map(function(item) {
      const idNum = Number(item.id)
      const imgSuffix = idNum >= 16 ? '..jpg' : '.jpg'
      return {
        id: item.id,
        title: item.name,
        count: String(Math.floor(Math.random() * 3000) + 7000),
        image: 'https://cdn.shijinzhuang.com/quick/jinancp/ktcp/' + String(item.id) + imgSuffix
      }
    })
  },

  goToTest(id) {
    router.push({
      uri: '/pages/KantuDetail',
      params: {
        id: String(id || 1)
      }
    })
  }
}
</script>

