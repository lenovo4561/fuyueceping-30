  flex-direction: row;
  justify-content: space-around;
  align-items: flex-end;
  width: 100%;
  height: 100%;
  padding-bottom: 0px;
}

.tab-item {
  width: 52px;
  height: 28px;
  border-radius: 14px;
  background-color: #ffffff;
  justify-content: center;
  align-items: center;
}

.active {
  background-color: #000000;
}

.tab-text {
  font-size: 12px;
  color: #333333;
}

.active-text {
  color: #ffffff;
}

.list-section {
  flex-direction: column;
  width: 100%;
  padding: 10px;
}

.list-item {
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 12px;
  padding: 12px;
  padding-left: 0px;
  padding-right: 5px;
  margin-bottom: 10px;
  align-items: center;
}

.item-img {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  object-fit: cover;
  margin-left: 8px;
}

.item-info {
  flex: 1;
  flex-direction: column;
  margin-left: 12px;
  height: 60px;
  justify-content: space-between;
}

.item-title {
  font-size: 10px;
  color: #333333;
  lines: 1;
  text-overflow: ellipsis;
  margin-top: 4px;
  font-weight: bold;
}

.item-bottom {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.item-tags {
  flex-direction: row;
}

.tag {
  background-color: #e6f6ff;
  color: #33aaff;
  font-size: 7px;
  padding: 1px 4px;
  border-radius: 2px;
  margin-right: 4px;
}

.btn-box {
  flex-direction: row;
}

.start-btn {
  background-color: #ff5500;
  color: #ffffff;
  font-size: 8px;
  padding: 5px 10px;
  border-radius: 10px;
}

